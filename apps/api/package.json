{
  "name": "@liberproof/api",
  "version": "0.1.0",
  "description": "LiberProof API — proof storage, SIWE auth, anchoring relay",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@liberproof/core": "workspace:*",
    "@liberproof/anchors": "workspace:*",
    "better-sqlite3": "^9.4.3",
    "hono": "^4.12.25",
    "jose": "^5.4.0",
    "viem": "^2.17.0",
    "zod": "^3.23.0",
    "@hono/zod-validator": "^0.2.0",
    "@noble/hashes": "^1.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^26.0.1",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}