{
  "name": "@sovegent/sdk",
  "version": "0.1.0",
  "description": "Sovegent Identity unified SDK — the main consumer-facing entry point",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sovegent/core": "workspace:*",
    "@sovegent/anchors": "workspace:*",
    "@sovegent/zk": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "vitest": "^1.6.0"
  }
}