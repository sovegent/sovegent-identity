{
  "name": "@liberproof/anchors",
  "version": "0.1.0",
  "description": "Chain-specific anchoring adapters (EVM, Liberland, Bitcoin)",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@liberproof/core": "workspace:*"
  },
  "peerDependencies": {
    "viem": "^2.0.0",
    "@stricahq/typhonjs": "^3.0.0",
    "@stricahq/bip32ed25519": "^1.0.0",
    "bignumber.js": "^9.0.0"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    },
    "@stricahq/typhonjs": {
      "optional": true
    },
    "@stricahq/bip32ed25519": {
      "optional": true
    },
    "bignumber.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
